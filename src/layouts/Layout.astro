---
import '../styles/global.css';
import Loader from '../components/Loader.astro';
import Nav from '../components/Nav.astro';
import CustomCursor from '../components/CustomCursor.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  showNav?: boolean;
}

const {
  title = 'Omar Álvarez — Consultor de IA para pymes LATAM',
  description = 'CEO de Enzo Motorsport y Arkhē Coworking. Integro IA en la operación real de pymes en Latinoamérica. Cúcuta, Colombia.',
  image = '/og-image.svg',
  showNav = true,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <meta name="theme-color" content="#0A0A0A" />

    <!-- Schema.org Person + ProfessionalService -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "name": "Omar Álvarez",
          "jobTitle": "Consultor de IA para pymes LATAM",
          "url": canonicalURL.toString(),
          "email": "omaraalvarezo@gmail.com",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Cúcuta",
            "addressCountry": "CO"
          },
          "alumniOf": [
            { "@type": "EducationalOrganization", "name": "Universidad EAFIT" },
            { "@type": "EducationalOrganization", "name": "Universidad Pontificia Bolivariana" },
            { "@type": "EducationalOrganization", "name": "La Salle Barcelona" }
          ]
        },
        {
          "@type": "ProfessionalService",
          "name": "Omar Álvarez · IA aplicada a pymes",
          "url": canonicalURL.toString(),
          "areaServed": ["CO", "MX", "PE", "CL", "ES"],
          "priceRange": "$$"
        }
      ]
    })}></script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[120] focus:bg-accent focus:px-4 focus:py-2 focus:text-bg focus:rounded-sm"
    >
      Saltar al contenido
    </a>

    <Loader />
    <ScrollProgress />
    <CustomCursor />
    {showNav && <Nav />}

    <main id="main">
      <span id="top" class="sr-only" aria-hidden="true"></span>
      <slot />
    </main>

    <WhatsAppFloat />

    <script>
      import { initLenis } from '../scripts/lenis';
      initLenis();
    </script>
  </body>
</html>
