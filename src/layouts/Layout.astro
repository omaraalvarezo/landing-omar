---
import '../styles/global.css';
import Loader from '../components/Loader.astro';
import Nav from '../components/Nav.astro';
import CustomCursor from '../components/CustomCursor.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  showNav?: boolean;
}

const {
  title = 'omar.alvarez — Negocios reales, código real',
  description = 'Operador de dos negocios. Documento IA aplicada y operación para emprendimientos pequeños y medianos en LATAM. Sin teoría, sin gurús.',
  image = '/og-image.svg',
  showNav = true,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Anti-FOUC: aplica tema antes del primer paint.
         Lee localStorage 'omar-theme'; si no existe, respeta prefers-color-scheme. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('omar-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <!-- Favicon dual: light + dark según prefers-color-scheme del SO -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <meta name="theme-color" content="#FAFAF9" />

    <!-- Schema.org Person + ProfessionalService -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "name": "Omar Álvarez",
          "jobTitle": "Operador",
          "description": "Documento IA aplicada y operación para emprendimientos pequeños y medianos en LATAM.",
          "url": canonicalURL.toString(),
          "email": "omaraalvarezo@gmail.com",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "CO"
          },
          "alumniOf": [
            { "@type": "EducationalOrganization", "name": "Universidad EAFIT" },
            { "@type": "EducationalOrganization", "name": "Universidad Pontificia Bolivariana" },
            { "@type": "EducationalOrganization", "name": "La Salle Barcelona" }
          ]
        },
        {
          "@type": "ProfessionalService",
          "name": "omar.alvarez · IA aplicada a operación",
          "url": canonicalURL.toString(),
          "areaServed": ["CO", "MX", "PE", "CL", "ES"],
          "priceRange": "$$"
        }
      ]
    })}></script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[120] focus:bg-accent focus:px-4 focus:py-2 focus:text-bg focus:rounded-sm"
      style="font-family: var(--font-mono);"
    >
      Saltar al contenido
    </a>

    <Loader />
    <ScrollProgress />
    <CustomCursor />
    {showNav && <Nav />}

    <main id="main">
      <span id="top" class="sr-only" aria-hidden="true"></span>
      <slot />
    </main>

    <WhatsAppFloat />

    <script>
      import { initLenis } from '../scripts/lenis';
      initLenis();
    </script>

    <!-- Theme toggle: sincroniza estado del botón con [data-theme] y persiste en localStorage.
         Vive aquí (no en Nav.astro) para evitar duplicación si la nav re-renderiza. -->
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var meta = document.querySelector('meta[name="theme-color"]');

        function apply(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          btn.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
          btn.setAttribute('aria-label', theme === 'dark' ? 'Cambiar a tema claro' : 'Cambiar a tema oscuro');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#0D0D0D' : '#FAFAF9');
          try { localStorage.setItem('omar-theme', theme); } catch (e) {}
        }

        var current = document.documentElement.getAttribute('data-theme') || 'light';
        apply(current);

        btn.addEventListener('click', function () {
          var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          apply(next);
        });

        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        if (mq.addEventListener) {
          mq.addEventListener('change', function (e) {
            // Si el usuario nunca tocó el toggle, seguir al SO en tiempo real
            try {
              if (!localStorage.getItem('omar-theme')) apply(e.matches ? 'dark' : 'light');
            } catch (err) {}
          });
        }
      })();
    </script>
  </body>
</html>
