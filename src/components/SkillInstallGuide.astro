---
// Bloque editorial exclusivo del área /recursos/skills-claude.
// Explica en 3 pasos cómo instalar un skill descargado en el Claude Code del visitante.
import { ExternalLink } from '@lucide/astro';

const STEPS = [
  {
    n: '01',
    title: 'Descarga el .md',
    body: 'Elegí un skill de la lista de abajo y dale a "descargar". Vas a recibir un archivo Markdown con el frontmatter listo.',
  },
  {
    n: '02',
    title: 'Pégalo en tu carpeta de skills',
    body: 'Cada skill se guarda como SKILL.md dentro de su propia carpeta. Si tu Claude Code es local, va aquí:',
    code: 'mkdir -p ~/.claude/skills/{nombre-del-skill}\nmv ~/Downloads/{archivo}.md ~/.claude/skills/{nombre-del-skill}/SKILL.md',
  },
  {
    n: '03',
    title: 'Abrí Claude Code y listo',
    body: 'En tu próxima sesión, el skill aparece en la lista del tool Skill. Se activa solo cuando coincide con tu petición (según el campo description del frontmatter).',
  },
];
---

<section class="skill-guide" aria-labelledby="skill-guide-title">
  <header class="skill-guide__head">
    <p class="mono-label skill-guide__label">cómo instalar</p>
    <h3 id="skill-guide-title" class="skill-guide__title">
      Tres pasos. Cero configuración.
    </h3>
  </header>

  <ol class="skill-guide__steps" role="list">
    {STEPS.map((s) => (
      <li class="skill-guide__step">
        <p class="skill-guide__step-num">{s.n}</p>
        <h4 class="skill-guide__step-title">{s.title}</h4>
        <p class="skill-guide__step-body">{s.body}</p>
        {s.code && (
          <pre class="skill-guide__code"><code>{s.code}</code></pre>
        )}
      </li>
    ))}
  </ol>

  <footer class="skill-guide__foot">
    <a
      href="https://docs.claude.com/en/docs/claude-code/skills"
      target="_blank"
      rel="noopener"
      class="skill-guide__doc-link"
    >
      ¿qué son las skills de Claude Code?
      <ExternalLink size={12} stroke-width={1.5} aria-hidden="true" />
    </a>
  </footer>
</section>

<style>
  .skill-guide {
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 4vw, 40px);
    padding: clamp(32px, 5vw, 56px) clamp(24px, 4vw, 48px);
    border: 0.5px solid var(--line);
    background-color: var(--bg-soft);
    border-radius: 4px;
  }

  .skill-guide__head {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .skill-guide__label {
    margin: 0;
    color: var(--mute);
  }

  .skill-guide__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    font-weight: 400;
    color: var(--ink);
    max-width: 18ch;
  }

  .skill-guide__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .skill-guide__steps {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 32px;
    }
  }

  .skill-guide__step {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .skill-guide__step-num {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .skill-guide__step-title {
    margin: 0;
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    font-weight: 500;
    color: var(--ink);
  }

  .skill-guide__step-body {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--mute);
  }

  .skill-guide__code {
    margin: 8px 0 0;
    padding: 12px 16px;
    background-color: var(--bg);
    border-left: 2px solid var(--accent);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.6;
    color: var(--ink-soft);
    overflow-x: auto;
    white-space: pre;
    border-radius: 0;
  }

  .skill-guide__foot {
    display: flex;
  }

  .skill-guide__doc-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--mute);
    border-bottom: 1px solid var(--line-hi);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .skill-guide__doc-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
