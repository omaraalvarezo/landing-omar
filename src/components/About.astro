---
import SectionLabel from './SectionLabel.astro';

const STATS = [
  { label: 'MBA', value: 'EAFIT (Medellín, intercambio La Salle Barcelona)' },
  { label: 'Ing. Electrónico', value: 'UPB Medellín' },
  { label: 'CEO', value: 'Enzo Motorsport + Arkhē Coworking' },
  { label: 'Base', value: 'Colombia' },
];
---

<section id="sobre" class="about scroll-mt-24" aria-labelledby="about-title">
  <div class="container-page about__grid">
    <div class="about__label">
      <SectionLabel number="05" title="SOBRE" />
    </div>

    <div class="about__content">
      <div class="about__layout">
        <!-- Foto placeholder con duotono lima en hover -->
        <figure class="about__photo" aria-label="Foto de Omar Álvarez (placeholder)">
          <div class="about__photo-inner">
            <span class="about__photo-glyph" aria-hidden="true">OA</span>
          </div>
        </figure>

        <div class="about__body">
          <h2 id="about-title" class="h2-section about__headline" data-split-reveal style="--reveal-stagger: 35ms;">
            No soy consultor de <span class="accent-italic">PowerPoint</span>.
          </h2>

          <p class="about__bio" data-reveal>
            Opero dos negocios reales todos los días — vendo servicios automotrices premium en <strong>Enzo Motorsport</strong> y gestiono un coworking de 240m² en <strong>Arkhē</strong>. Lo que te enseño lo uso primero conmigo mismo.
          </p>

          <ul class="about__stats" data-reveal>
            {STATS.map(({ label, value }) => (
              <li class="about__stat">
                <span class="about__stat-label">{label}</span>
                <span class="about__stat-sep" aria-hidden="true">·</span>
                <span class="about__stat-value">{value}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding-block: clamp(96px, 14vw, 200px);
    border-top: 0.5px solid var(--border);
  }
  .about__grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
  }
  .about__content {
    display: flex;
    flex-direction: column;
  }

  .about__layout {
    display: grid;
    gap: clamp(28px, 4vw, 56px);
    grid-template-columns: 1fr;
    align-items: start;
  }

  /* Photo */
  .about__photo {
    margin: 0;
    aspect-ratio: 4 / 5;
    width: 100%;
    max-width: 360px;
    overflow: hidden;
    border-radius: 4px;
    border: 0.5px solid var(--border);
    background-color: var(--bg-elev);
    position: relative;
    isolation: isolate;
  }
  .about__photo-inner {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 30%, rgba(232,255,79,0.15), transparent 60%),
      linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
    display: grid;
    place-items: center;
    transition: filter 0.6s var(--ease-out-expo);
  }
  .about__photo:hover .about__photo-inner {
    filter: hue-rotate(-30deg) saturate(1.3);
  }
  .about__photo-glyph {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: clamp(72px, 12vw, 140px);
    line-height: 1;
    color: var(--accent);
    opacity: 0.9;
    letter-spacing: -0.04em;
  }

  /* Body */
  .about__body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about__headline {
    margin: 0;
    max-width: 16ch;
  }

  .about__bio {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-mute);
    max-width: 50ch;
  }
  .about__bio strong {
    color: var(--text);
    font-weight: 500;
  }

  .about__stats {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-top: 0.5px solid var(--border);
    padding-top: 24px;
  }
  .about__stat {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    font-size: 14px;
  }
  .about__stat-label {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    min-width: 110px;
  }
  .about__stat-sep { color: var(--text-dim); }
  .about__stat-value { color: var(--text); }

  /* Tablet+ */
  @media (min-width: 768px) {
    .about__layout {
      grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
      gap: 56px;
    }
  }

  @media (min-width: 1024px) {
    .about__grid {
      grid-template-columns: 200px minmax(0, 1fr);
      gap: 48px;
    }
  }
</style>
