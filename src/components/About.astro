---
import SectionLabel from './SectionLabel.astro';

const STATS = [
  { label: 'MBA', value: 'EAFIT (Medellín, intercambio La Salle Barcelona)' },
  { label: 'Ing. Electrónico', value: 'UPB Medellín' },
  { label: 'CEO', value: 'Enzo Motorsport + Arkhē Coworking' },
  { label: 'Base', value: 'Colombia' },
];
---

<section id="sobre" class="about scroll-mt-24" aria-labelledby="about-title">
  <div class="container-page about__grid">
    <div class="about__label">
      <SectionLabel number="05" title="SOBRE" />
    </div>

    <div class="about__content">
      <div class="about__layout">
        <!-- Foto placeholder editorial: bg --bg-soft + glifo o.a en serif -->
        <figure class="about__photo" aria-label="omar.alvarez · retrato (placeholder)">
          <div class="about__photo-inner">
            <span class="about__photo-glyph" aria-hidden="true">o<span class="about__photo-dot">.</span>a</span>
          </div>
        </figure>

        <div class="about__body">
          <h2 id="about-title" class="h2-section about__headline" data-split-reveal style="--reveal-stagger: 35ms;">
            Operador de dos negocios. Documento lo que construyo.
          </h2>

          <p class="about__bio" data-reveal>
            <strong>Enzo Motorsport</strong> (servicios automotrices premium) y <strong>Arkhē Coworking</strong> (240 m²). Sin teoría, sin gurús. Lo que documento lo uso primero conmigo mismo.
          </p>

          <ul class="about__stats" data-reveal>
            {STATS.map(({ label, value }) => (
              <li class="about__stat">
                <span class="about__stat-label">{label}</span>
                <span class="about__stat-sep" aria-hidden="true">·</span>
                <span class="about__stat-value">{value}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding-block: clamp(96px, 14vw, 200px);
    border-top: 0.5px solid var(--line);
  }
  .about__grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
  }
  .about__content {
    display: flex;
    flex-direction: column;
  }

  .about__layout {
    display: grid;
    gap: clamp(28px, 4vw, 56px);
    grid-template-columns: 1fr;
    align-items: start;
  }

  /* Photo placeholder */
  .about__photo {
    margin: 0;
    aspect-ratio: 4 / 5;
    width: 100%;
    max-width: 360px;
    overflow: hidden;
    border: 0.5px solid var(--line);
    background-color: var(--bg-soft);
    position: relative;
    isolation: isolate;
  }
  .about__photo-inner {
    position: absolute;
    inset: 0;
    background-color: var(--bg-soft);
    display: grid;
    place-items: center;
  }
  .about__photo-glyph {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: clamp(72px, 12vw, 140px);
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.025em;
  }
  .about__photo-dot {
    color: var(--accent);
  }

  /* Body */
  .about__body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about__headline {
    margin: 0;
    max-width: 16ch;
  }

  .about__bio {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--mute);
    max-width: 50ch;
  }
  .about__bio strong {
    color: var(--ink);
    font-weight: 500;
  }

  .about__stats {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-top: 0.5px solid var(--line);
    padding-top: 24px;
  }
  .about__stat {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    font-size: 14px;
  }
  .about__stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    font-weight: 500;
    min-width: 110px;
  }
  .about__stat-sep { color: var(--mute); }
  .about__stat-value { color: var(--ink); }

  /* Tablet+ */
  @media (min-width: 768px) {
    .about__layout {
      grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
      gap: 56px;
    }
  }

  @media (min-width: 1024px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
