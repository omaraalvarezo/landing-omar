---
import { EMAIL, LOCATION, SOCIALS, whatsappUrl } from '../lib/contact';
import Logo from './Logo.astro';

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const anchor = (hash: string) => (isHome ? hash : `/${hash}`);

const NAV_LINKS = [
  { href: anchor('#servicios'), label: 'servicios' },
  { href: anchor('#metodo'), label: 'método' },
  { href: anchor('#casos'), label: 'casos' },
  { href: anchor('#sobre'), label: 'sobre' },
  { href: '/recursos', label: 'recursos' },
  { href: anchor('#faq'), label: 'faq' },
  { href: anchor('#contacto'), label: 'contacto' },
];

const CONTACT_LINKS = [
  { href: `mailto:${EMAIL}`, label: 'email' },
  { href: whatsappUrl('Hola Omar'), label: 'whatsapp' },
  { href: SOCIALS.instagram, label: 'instagram' },
  { href: SOCIALS.tiktok, label: 'tiktok' },
  { href: SOCIALS.linkedin, label: 'linkedin' },
];

const year = new Date().getFullYear();
---

<footer class="footer" aria-label="Pie de página">
  <div class="container-page footer__grid">
    <div class="footer__col footer__col--brand">
      <p class="footer__logo">
        <Logo variant="horizontal" size={18} />
      </p>
      <p class="footer__tagline">
        Negocios reales, código real.
      </p>
      <p class="footer__copy">© {year} · {LOCATION}</p>
    </div>

    <nav class="footer__col" aria-label="Navegación">
      <p class="footer__col-label">navegación</p>
      <ul>
        {NAV_LINKS.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Contacto">
      <p class="footer__col-label">contacto</p>
      <ul>
        {CONTACT_LINKS.map((l) => (
          <li>
            <a
              href={l.href}
              target={l.href.startsWith('mailto:') ? '_self' : '_blank'}
              rel="noopener"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="footer__col">
      <p class="footer__col-label">construido</p>
      <p class="footer__small">astro · tailwind · motion one · lenis</p>
      <p class="footer__small">deployado en vercel</p>
      <p class="footer__small">diseño + código por omar</p>
    </div>
  </div>

  <!-- Cierre estilo slide 8 del brandbook v2.1: fondo --ink, wordmark grande con punto azul -->
  <div class="footer__finale" aria-hidden="true">
    <Logo variant="horizontal" size={120} inverse class="footer__wordmark" />
  </div>
</footer>

<style>
  .footer {
    padding-top: clamp(80px, 12vw, 140px);
    padding-bottom: 0;
    border-top: 0.5px solid var(--line);
    background-color: var(--bg);
    overflow: hidden;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: clamp(60px, 10vw, 120px);
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__col--brand .footer__logo {
    display: inline-flex;
    align-items: center;
    margin: 0;
  }
  .footer__tagline {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.5;
    color: var(--ink-soft);
    letter-spacing: -0.015em;
    max-width: 36ch;
  }
  .footer__copy {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--mute);
    margin-top: 8px;
    letter-spacing: 0.04em;
  }

  .footer__col-label {
    margin: 0 0 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    font-weight: 500;
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer__col a {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-soft);
    transition: color 0.2s ease;
  }
  .footer__col a:hover {
    color: var(--accent);
  }

  .footer__small {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--mute);
    line-height: 1.6;
    letter-spacing: 0.04em;
  }

  /* Finale block — fondo --ink, wordmark grande con punto azul */
  .footer__finale {
    background-color: var(--ink);
    padding: clamp(64px, 10vw, 112px) var(--container-x);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .footer__finale :global(.footer__wordmark) {
    font-size: clamp(48px, 14vw, 180px) !important;
    line-height: 1;
    user-select: none;
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 32px;
    }
  }
</style>
