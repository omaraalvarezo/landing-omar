---
import { EMAIL, LOCATION, SOCIALS, whatsappUrl } from '../lib/contact';
import Logo from './Logo.astro';

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const anchor = (hash: string) => (isHome ? hash : `/${hash}`);

const NAV_LINKS = [
  { href: anchor('#servicios'), label: 'servicios' },
  { href: anchor('#metodo'), label: 'método' },
  { href: anchor('#casos'), label: 'casos' },
  { href: anchor('#sobre'), label: 'sobre' },
  { href: '/recursos', label: 'recursos' },
  { href: anchor('#faq'), label: 'faq' },
  { href: anchor('#contacto'), label: 'contacto' },
];

const CONTACT_LINKS = [
  { href: `mailto:${EMAIL}`, label: 'email' },
  { href: whatsappUrl('Hola Omar'), label: 'whatsapp' },
  { href: SOCIALS.instagram, label: 'instagram' },
  { href: SOCIALS.tiktok, label: 'tiktok' },
  { href: SOCIALS.linkedin, label: 'linkedin' },
];

const today = new Date();
const year = today.getFullYear();
const buildStamp = `${year}.${String(today.getMonth() + 1).padStart(2, '0')}.${String(today.getDate()).padStart(2, '0')}`;
---

<footer class="footer" aria-label="Pie de página">
  <div class="container-page footer__grid">
    <div class="footer__col footer__col--brand">
      <p class="footer__logo">
        <Logo variant="horizontal" size={18} />
      </p>
      <p class="footer__tagline">
        Negocios reales, código real.
      </p>
      <p class="footer__copy">© {year} · {LOCATION}</p>
    </div>

    <nav class="footer__col" aria-label="Navegación">
      <p class="footer__col-label">navegación</p>
      <ul>
        {NAV_LINKS.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Contacto">
      <p class="footer__col-label">contacto</p>
      <ul>
        {CONTACT_LINKS.map((l) => (
          <li>
            <a
              href={l.href}
              target={l.href.startsWith('mailto:') ? '_self' : '_blank'}
              rel="noopener"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="footer__col">
      <p class="footer__col-label">construido</p>
      <p class="footer__small">astro · tailwind · motion one · lenis</p>
      <p class="footer__small">deployado en vercel</p>
      <p class="footer__small">diseño + código por omar</p>
    </div>
  </div>

  <!-- Cierre editorial minimal: statement serif + wordmark mediano + firma mono.
       Sobre --bg (no bloque oscuro), funciona limpio en light y dark. -->
  <div class="footer__finale">
    <div class="footer__finale-inner container-page">
      <p class="footer__finale-pretitle">
        <span>FIN · COL.III</span>
        <span aria-hidden="true">·</span>
        <span>EDICIÓN {year}</span>
      </p>

      <p class="footer__finale-line">
        No hay magia. Hay <span class="footer__finale-italic">criterio</span>, datos y código.
      </p>

      <div class="footer__finale-wordmark">
        <Logo variant="horizontal" size={36} class="footer__wordmark" />
      </div>

      <p class="footer__finale-signature">
        <span>© {year} omar.alvarez · {LOCATION}</span>
        <span aria-hidden="true">·</span>
        <span>build · {buildStamp}</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-top: clamp(80px, 12vw, 140px);
    padding-bottom: 0;
    border-top: 0.5px solid var(--line);
    background-color: var(--bg);
    overflow: hidden;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: clamp(60px, 10vw, 120px);
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__col--brand .footer__logo {
    display: inline-flex;
    align-items: center;
    margin: 0;
  }
  .footer__tagline {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.5;
    color: var(--ink-soft);
    letter-spacing: -0.015em;
    max-width: 36ch;
  }
  .footer__copy {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--mute);
    margin-top: 8px;
    letter-spacing: 0.04em;
  }

  .footer__col-label {
    margin: 0 0 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    font-weight: 500;
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer__col a {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-soft);
    transition: color 0.2s ease;
  }
  .footer__col a:hover {
    color: var(--accent);
  }

  .footer__small {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--mute);
    line-height: 1.6;
    letter-spacing: 0.04em;
  }

  /* Finale block — cinta editorial sobre --bg.
     Sin background inverso: funciona idéntico en light y dark. */
  .footer__finale {
    background-color: var(--bg);
    border-top: 0.5px solid var(--line);
    color: var(--ink);
    padding: clamp(48px, 8vw, 88px) 0 clamp(32px, 5vw, 48px);
    overflow: hidden;
  }
  .footer__finale-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(20px, 3vw, 32px);
  }
  .footer__finale-pretitle {
    margin: 0;
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    font-weight: 500;
  }
  .footer__finale-pretitle span[aria-hidden='true'] {
    color: var(--line-hi);
  }
  .footer__finale-line {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(22px, 3vw, 36px);
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--ink-soft);
    max-width: 22ch;
  }
  .footer__finale-italic {
    font-style: italic;
    color: var(--ink);
    text-decoration-line: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.14em;
  }
  .footer__finale-wordmark {
    display: inline-flex;
    padding-top: clamp(8px, 2vw, 16px);
  }
  .footer__finale :global(.footer__wordmark) {
    font-size: clamp(28px, 4vw, 40px) !important;
    line-height: 1;
    user-select: none;
  }
  .footer__finale-signature {
    margin: 0;
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--mute);
  }
  .footer__finale-signature span[aria-hidden='true'] {
    color: var(--line-hi);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 32px;
    }
  }
</style>
