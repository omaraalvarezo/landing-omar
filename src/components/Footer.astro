---
import { EMAIL, LOCATION, SOCIALS, whatsappUrl } from '../lib/contact';

const NAV_LINKS = [
  { href: '#servicios', label: 'servicios' },
  { href: '#metodo', label: 'método' },
  { href: '#casos', label: 'casos' },
  { href: '#sobre', label: 'sobre' },
  { href: '#faq', label: 'faq' },
  { href: '#contacto', label: 'contacto' },
];

const CONTACT_LINKS = [
  { href: `mailto:${EMAIL}`, label: 'email' },
  { href: whatsappUrl('Hola Omar'), label: 'whatsapp' },
  { href: SOCIALS.instagram, label: 'instagram' },
  { href: SOCIALS.tiktok, label: 'tiktok' },
  { href: SOCIALS.linkedin, label: 'linkedin' },
];

const year = new Date().getFullYear();
---

<footer class="footer" aria-label="Pie de página">
  <div class="container-page footer__grid">
    <div class="footer__col footer__col--brand">
      <p class="footer__logo">omar álvarez</p>
      <p class="footer__tagline">
        ia aplicada a la operación real de pymes en latam.
      </p>
      <p class="footer__copy">© {year} omar álvarez · {LOCATION.toLowerCase()}</p>
    </div>

    <nav class="footer__col" aria-label="Navegación">
      <p class="footer__col-label">navegación</p>
      <ul>
        {NAV_LINKS.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Contacto">
      <p class="footer__col-label">contacto</p>
      <ul>
        {CONTACT_LINKS.map((l) => (
          <li>
            <a
              href={l.href}
              target={l.href.startsWith('mailto:') ? '_self' : '_blank'}
              rel="noopener"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="footer__col">
      <p class="footer__col-label">construido</p>
      <p class="footer__small">
        astro · tailwind · motion one · lenis
      </p>
      <p class="footer__small">
        deployado en vercel
      </p>
      <p class="footer__small">
        diseño + código por omar
      </p>
    </div>
  </div>

  <!-- Cierre dramático estilo Awwwards -->
  <div class="footer__finale" aria-hidden="true">
    <p class="footer__finale-text">
      OMAR <span class="accent-italic">ÁLVAREZ</span>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding-top: clamp(80px, 12vw, 140px);
    padding-bottom: 24px;
    border-top: 0.5px solid var(--border);
    background-color: var(--bg);
    overflow: hidden;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: clamp(60px, 10vw, 120px);
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__col--brand .footer__logo {
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
    margin: 0;
  }
  .footer__tagline {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-mute);
    max-width: 36ch;
  }
  .footer__copy {
    margin: 0;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    color: var(--text-dim);
    margin-top: 8px;
  }

  .footer__col-label {
    margin: 0 0 8px;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer__col a {
    font-size: 14px;
    color: var(--text-mute);
    transition: color 0.2s ease;
  }
  .footer__col a:hover {
    color: var(--accent);
  }

  .footer__small {
    margin: 0;
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* Finale block */
  .footer__finale {
    border-top: 0.5px solid var(--border);
    padding-top: clamp(48px, 8vw, 96px);
    text-align: center;
  }
  .footer__finale-text {
    margin: 0;
    font-size: clamp(56px, 18vw, 240px);
    line-height: 0.9;
    letter-spacing: -0.05em;
    font-weight: 500;
    color: var(--text);
    user-select: none;
  }
  .footer__finale-text .accent-italic {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    color: var(--accent);
    font-weight: 400;
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 32px;
    }
  }
</style>
