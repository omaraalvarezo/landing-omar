---
import SectionLabel from './SectionLabel.astro';
import CalEmbed from './CalEmbed.astro';

type AccentVariant = 'bronce' | 'terracota' | 'indigo' | 'musgo';

interface Service {
  n: string;
  title: string;
  meta: string;
  desc: string;
  bullets: string[];
  takeaway: { label: string; body: string }[];
  ctaText: string;
  accent: AccentVariant;
  flipped?: boolean;
  footer?: string;
}

const ACCENT_HEX: Record<AccentVariant, string> = {
  bronce: '#8B6F47',
  terracota: '#C67B5C',
  indigo: '#3D4E6B',
  musgo: '#6B7F5C',
};

const SERVICES: Service[] = [
  {
    n: '01',
    title: 'Claude a tu medida',
    meta: '1 sesión 90 min · consultar inversión',
    desc: 'Salimos de la sesión con Claude configurado para tu rol y tu negocio. Skills custom instaladas, prompts probados, archivos ordenados para que los lea bien, y un plan de uso semanal para que no se quede en la novedad de los primeros tres días.',
    bullets: [
      'Claude configurado para tu rol específico (no genérico)',
      'Skills custom instaladas en tu Claude Code o Claude Desktop',
      'Prompts probados que reemplazan 5-10 herramientas sueltas',
      'Tu cloud y archivos ordenados para que Claude los lea bien',
      'Documento con plan de uso semanal y casos concretos',
      'Follow-up async de 20 min dentro de 14 días para dudas de adopción',
    ],
    takeaway: [
      { label: 'Claude listo y entrenado', body: 'Configurado para tu rol y tu negocio, no como sale de la caja.' },
      { label: 'Plan de uso semanal', body: 'Casos concretos de cómo usarlo cada día sin pensarlo.' },
      { label: 'Stack ordenado', body: 'Tu cloud, archivos y herramientas alineados para que Claude los aproveche.' },
    ],
    ctaText: 'agendar onboarding →',
    accent: 'bronce',
  },
  {
    n: '02',
    title: 'Mapa de IA para tu negocio',
    meta: '2 semanas · 3 sesiones · consultar inversión',
    desc: 'Auditoría completa de tu operación para mapear dónde Claude y la IA pueden ahorrarte tiempo real y plata real. Salimos con un plan priorizado por ROI y la primera implementación bocetada lista para ejecutar.',
    bullets: [
      'Auditoría de operación, finanzas, equipo y stack tecnológico actual',
      'Mapa de 5-7 oportunidades donde la IA tiene retorno medible',
      'Cálculo de ROI defendible para cada oportunidad (no promesas)',
      'PDF ejecutivo 18-25 páginas + Notion vivo compartido',
      'Brief técnico de la primera implementación recomendada',
      'Plan de acción 90/180/365 días',
    ],
    takeaway: [
      { label: 'Plan de IA priorizado', body: 'Sabes qué hacer primero y por qué. Sin moda, con criterio.' },
      { label: 'ROI defendible', body: 'Cada oportunidad con números, no con promesas de gurú.' },
      { label: 'Primer brief listo', body: 'La primera implementación bocetada y validada contigo.' },
    ],
    ctaText: 'agendar onboarding →',
    accent: 'terracota',
    flipped: true,
  },
  {
    n: '03',
    title: 'Implementación a tu medida',
    meta: '4-6 semanas · solo post-Mapa · consultar inversión',
    desc: 'Tomo la primera oportunidad del mapa y la construyo dentro de tu operación. Skills de Claude personalizadas, automatizaciones, dashboards. Tu equipo termina entrenado para sostenerlo sin depender de mí.',
    bullets: [
      'Construcción técnica (Claude skills, agentes, automatizaciones, dashboards)',
      'Sesión de pruebas piloto + iteración con feedback real',
      'Entrenamiento al equipo + documentación de uso y mantenimiento',
      'Métricas antes/después acordadas y medidas',
      'Tres rangos según complejidad: Esencial · Estándar · Avanzado',
    ],
    takeaway: [
      { label: 'Sistema operando', body: 'Andando en tu negocio real, no en demos. Indicadores desde el día uno.' },
      { label: 'Equipo entrenado', body: 'Tu gente sabe operarlo, mantenerlo y extenderlo sin atarte a mí.' },
      { label: 'Documentación viva', body: 'Notion con arquitectura, prompts, casos excepcionales y troubleshooting.' },
    ],
    ctaText: 'agendar onboarding →',
    accent: 'indigo',
    footer: 'Acceso solo para clientes que pasaron por el Mapa de IA.',
  },
  {
    n: '04',
    title: 'Acompañamiento mensual',
    meta: 'mes a mes · sin permanencia · consultar inversión',
    desc: 'Tu CTO de IA fraccional. Cada mes ordenamos tu data en un dashboard ejecutivo, validamos tus decisiones técnicas y avanzamos en nuevas implementaciones de Claude dentro de tu operación.',
    bullets: [
      '2 sesiones mensuales (60 min cada una)',
      'Dashboard ejecutivo mensual con tus archivos operativos y financieros',
      'Validación continua de decisiones técnicas, herramientas e inversiones',
      'WhatsApp asíncrono con respuesta dentro de 24h hábiles',
      'Acceso a mis skills y plantillas de Claude probadas en Enzo y Arkhē',
      'Tres tiers: Light (sin dashboard) · Estándar · Plus',
    ],
    takeaway: [
      { label: 'Dashboard mensual', body: 'Tu negocio ordenado con alertas y decisiones recomendadas cada mes.' },
      { label: 'Decisiones validadas', body: 'Antes de comprar herramientas o contratar gente, lo discutimos.' },
      { label: 'Continuidad', body: 'Conozco tu negocio mes a mes. Avanzamos sin reexplicar el contexto.' },
    ],
    ctaText: 'agendar onboarding →',
    accent: 'musgo',
    flipped: true,
  },
];
---

<section id="servicios" class="services scroll-mt-24" aria-labelledby="services-title">
  <div class="container-page services__grid">
    <div class="services__label">
      <SectionLabel number="02" title="SERVICIOS" />
    </div>

    <div class="services__content">
      <h2 id="services-title" class="h2-section services__headline" data-split-reveal style="--reveal-stagger: 35ms;">
        Cuatro formas de poner Claude a trabajar en tu <span class="accent-italic">operación</span>.
      </h2>

      <ul class="services__list" role="list">
        {SERVICES.map((s) => (
          <li
            class={`service-card service-card--${s.accent}${s.flipped ? ' service-card--flipped' : ''}`}
            style={`--service-accent: ${ACCENT_HEX[s.accent]};`}
            data-reveal
          >
            <div class="service-card__main">
              <p class="service-card__num">{s.n}</p>
              <div class="service-card__head">
                <h3 class="service-card__title">{s.title}</h3>
                <p class="service-card__meta">{s.meta}</p>
              </div>
              <p class="service-card__desc">{s.desc}</p>
              <ul class="service-card__bullets" role="list">
                {s.bullets.map((b) => (
                  <li>
                    <span class="service-card__check" aria-hidden="true">+</span>
                    {b}
                  </li>
                ))}
              </ul>
              <CalEmbed text={s.ctaText} variant={s.accent} />
              {s.footer && (
                <p class="service-card__footer">{s.footer}</p>
              )}
            </div>

            <aside class="service-card__aside" aria-label={`Qué te llevas con ${s.title}`}>
              <p class="service-card__aside-label">Qué te llevas</p>
              <ul class="service-card__takeaway" role="list">
                {s.takeaway.map((t) => (
                  <li>
                    <p class="service-card__takeaway-label">{t.label}</p>
                    <p class="service-card__takeaway-body">{t.body}</p>
                  </li>
                ))}
              </ul>
            </aside>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .services {
    padding-block: clamp(96px, 14vw, 200px);
    border-top: 0.5px solid var(--line);
  }

  .services__grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
  }

  .services__content {
    display: flex;
    flex-direction: column;
    gap: clamp(40px, 6vw, 80px);
  }

  .services__headline {
    margin: 0;
    max-width: 18ch;
  }

  .services__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 16px;
  }

  .service-card {
    border: 0.5px solid var(--line);
    border-radius: 4px;
    background-color: var(--bg);
    overflow: hidden;
    transition: border-color 0.3s ease;
    display: grid;
    grid-template-columns: 1fr;
  }
  .service-card:hover { border-color: var(--service-accent, var(--line-hi)); }
  .service-card:hover .service-card__num { color: var(--service-accent, var(--accent)); }

  .service-card__main {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .service-card__num {
    font-family: var(--font-mono);
    font-size: clamp(56px, 8vw, 88px);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--mute);
    margin: 0;
    transition: color 0.4s var(--ease-out-expo);
  }

  .service-card__head {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .service-card__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(28px, 3.5vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    font-weight: 400;
    color: var(--ink);
  }

  .service-card__meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mute);
  }

  .service-card__desc {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 56ch;
  }

  .service-card__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 0.5px solid var(--line);
    padding-top: 20px;
  }
  .service-card__bullets li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .service-card__check {
    flex-shrink: 0;
    font-family: var(--font-mono);
    color: var(--service-accent, var(--accent));
    line-height: 1.55;
  }

  .service-card__footer {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--mute);
    font-style: italic;
  }

  /* Aside (qué te llevas) */
  .service-card__aside {
    background-color: var(--bg-soft);
    border-top: 0.5px solid var(--line);
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .service-card__aside-label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--service-accent, var(--mute));
  }

  .service-card__takeaway {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .service-card__takeaway li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--line);
  }
  .service-card__takeaway li:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }
  .service-card__takeaway-label {
    margin: 0;
    font-size: 14px;
    color: var(--ink);
    font-weight: 500;
  }
  .service-card__takeaway-body {
    margin: 0;
    font-size: 13px;
    color: var(--mute);
    line-height: 1.55;
  }

  /* Tablet+ — layout asimétrico horizontal */
  @media (min-width: 900px) {
    .service-card {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    }
    .service-card__main {
      padding: 40px 36px 44px;
      gap: 24px;
    }
    .service-card__aside {
      border-top: 0;
      border-left: 0.5px solid var(--line);
      padding: 40px 32px;
    }
    .service-card--flipped .service-card__main { order: 2; border-left: 0.5px solid var(--line); }
    .service-card--flipped .service-card__aside { order: 1; border-left: 0; }
  }

  @media (min-width: 1024px) {
    .services__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
