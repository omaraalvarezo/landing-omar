---
import { type Resource, formatSize } from '../lib/resources';
import { ArrowRight } from '@lucide/astro';

interface Props {
  resource: Resource;
}
const { resource } = Astro.props;

const detailUrl = `/recursos/${resource.area}/${resource.slug}`;
const fileExt = (resource.fileName.split('.').pop() ?? 'md').toLowerCase();
const isSkill = resource.tipo === 'skill';
const isAdaptable = !!(resource.howToAdapt && resource.howToAdapt.length > 0);
---

<a
  href={detailUrl}
  class="resource-card"
  data-reveal
  data-tipo={resource.tipo}
  data-magnetic
  data-magnetic-strength="0.10"
  aria-label={`Ver detalle de ${resource.title}`}
>
  <header class="resource-card__head">
    {isAdaptable && (
      <span class="resource-card__badge" aria-label="Recurso adaptable a tu negocio">adaptable</span>
    )}
    <p class="resource-card__meta">
      {isSkill && resource.skillTrigger ? (
        <span class="resource-card__skill-trigger">{resource.skillTrigger}</span>
      ) : (
        <>
          <span class="resource-card__tipo">{resource.tipo}</span>
          <span class="resource-card__sep" aria-hidden="true">·</span>
          <span class="resource-card__filetype">{fileExt}</span>
        </>
      )}
    </p>
    <h3 class="resource-card__title">{resource.title}</h3>
  </header>

  <p class="resource-card__desc">{resource.description}</p>

  <footer class="resource-card__foot">
    <p class="resource-card__stats">
      <span>{formatSize(resource.sizeBytes)}</span>
      <span class="resource-card__sep" aria-hidden="true">·</span>
      <span>{resource.updatedAt}</span>
    </p>
    <span class="resource-card__more">
      <span>ver detalle</span>
      <ArrowRight size={14} stroke-width={1.5} aria-hidden="true" />
    </span>
  </footer>
</a>

<style>
  .resource-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 28px 24px;
    border: 0.5px solid var(--line);
    border-radius: 4px;
    background-color: var(--bg);
    color: var(--ink);
    transition:
      transform 0.4s var(--ease-out-expo),
      border-color 0.3s ease,
      opacity 0.4s ease;
    isolation: isolate;
    height: 100%;
    text-decoration: none;
  }
  .resource-card:hover {
    transform: translateY(-2px);
    border-color: var(--line-hi);
  }
  .resource-card:hover .resource-card__tipo,
  .resource-card:hover .resource-card__skill-trigger {
    color: var(--accent);
  }
  .resource-card:hover .resource-card__more {
    color: var(--accent);
  }
  .resource-card:hover .resource-card__more svg {
    transform: translateX(4px);
  }
  .resource-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .resource-card[data-hidden='true'] {
    display: none;
  }

  .resource-card__head {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .resource-card__badge {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 3px 8px;
    border: 0.5px solid var(--accent);
    border-radius: 2px;
    margin-bottom: -2px;
  }

  .resource-card__meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mute);
  }

  .resource-card__tipo,
  .resource-card__filetype,
  .resource-card__sep {
    color: var(--mute);
    transition: color 0.3s ease;
  }

  .resource-card__skill-trigger {
    color: var(--mute);
    letter-spacing: 0.04em;
    text-transform: none;
    transition: color 0.3s ease;
  }

  .resource-card__title {
    margin: 0;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 500;
    color: var(--ink);
  }

  .resource-card__desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--mute);
    flex-grow: 1;
  }

  .resource-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border-top: 0.5px solid var(--line);
    padding-top: 16px;
  }

  .resource-card__stats {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--mute);
  }

  .resource-card__more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--ink);
    transition: color 0.3s ease;
  }
  .resource-card__more svg {
    transition: transform 0.4s var(--ease-out-expo);
  }
</style>
