---
import SectionLabel from './SectionLabel.astro';
import { MessageCircle, ChartColumn, Ship } from '@lucide/astro';
import { whatsappUrl } from '../lib/contact';

const ctaUrl = whatsappUrl('Hola Omar, vi los casos y quiero que el mío sea el cuarto.');
---

<section id="casos" class="cases scroll-mt-24" aria-labelledby="cases-title">
  <div class="container-page cases__grid">
    <div class="cases__label">
      <SectionLabel number="04" title="CASOS" />
    </div>

    <div class="cases__content">
      <h2 id="cases-title" class="h2-section cases__headline" data-split-reveal style="--reveal-stagger: 35ms;">
        Tres negocios. Tres formas de <span class="accent-italic">apalancar</span> con IA.
      </h2>

      <div class="cases__bento">
        <!-- Caso 1: Enzo (grande) -->
        <article class="case case--lg" data-reveal>
          <div class="case__head">
            <div class="case__meta">
              <MessageCircle class="case__icon" size={18} stroke-width={1.5} aria-hidden="true" />
              <span>enzo motorsport · sector automotriz</span>
            </div>
            <h3 class="case__title">Tablero financiero + reporte diario por WhatsApp</h3>
            <p class="case__desc">
              Reporte automático cada 8pm con ventas del día, porcentaje de insumos y márgenes por servicio. Asistente que responde preguntas sobre el negocio.
            </p>
            <ul class="case__metrics">
              <li><strong>$81M</strong><span>cop/mes operados</span></li>
              <li><strong>3hr</strong><span>ahorro diario en reportes</span></li>
              <li><strong>1</strong><span>persona vs equipo de finanzas</span></li>
            </ul>
          </div>

          <!-- Mockup visual: bot WhatsApp -->
          <div class="case__visual case__visual--whatsapp" aria-hidden="true">
            <div class="wa">
              <div class="wa__head">
                <span class="wa__avatar"></span>
                <div>
                  <p class="wa__name">enzo · reporte 8pm</p>
                  <p class="wa__status">en línea</p>
                </div>
              </div>
              <div class="wa__bubble">
                <p class="wa__line"><strong>$3.4M</strong> ventas hoy</p>
                <p class="wa__line">PPF · 2 servicios · margen 68%</p>
                <p class="wa__line">cerámico · 3 servicios · margen 72%</p>
                <p class="wa__line">insumos: 18% (target ≤17%)</p>
                <p class="wa__line wa__line--alert">alert: cita JD mañana 9am sin confirmar</p>
              </div>
              <div class="wa__bubble wa__bubble--user">
                <p>¿cómo vamos vs la semana pasada?</p>
              </div>
              <div class="wa__bubble">
                <p class="wa__line">+12.3% vs misma fecha sem-1</p>
                <p class="wa__line">PPF traccionando, polarizado plano</p>
              </div>
            </div>
          </div>
        </article>

        <!-- Caso 2: Arkhē -->
        <article class="case" data-reveal>
          <div class="case__head">
            <div class="case__meta">
              <ChartColumn class="case__icon" size={18} stroke-width={1.5} aria-hidden="true" />
              <span>arkhē coworking · 240m²</span>
            </div>
            <h3 class="case__title">Análisis de 1,340 reservas históricas</h3>
            <p class="case__desc">
              Análisis de patrones de uso por día y hora. Identificación de la franja de baja ocupación 12pm–4pm que perdía 41% de los ingresos potenciales.
            </p>
          </div>

          <!-- Mockup visual: mini bar chart con valle -->
          <div class="case__visual case__visual--chart" aria-hidden="true">
            <p class="chart__caption">ocupación por hora · l-v</p>
            <div class="chart">
              {[55, 78, 88, 92, 60, 38, 32, 35, 48, 72, 84, 88].map((h, i) => (
                <span class="chart__bar" style={`--h: ${h}%; --i: ${i};`}></span>
              ))}
              <span class="chart__annotation" aria-hidden="true">
                <span class="chart__annotation-line"></span>
                <span class="chart__annotation-label">−41% ingresos potenciales</span>
              </span>
            </div>
            <div class="chart__legend">
              <span>8am</span>
              <span class="chart__valley">valle 12—4pm</span>
              <span>8pm</span>
            </div>
          </div>
        </article>

        <!-- Caso 3: O&P -->
        <article class="case" data-reveal>
          <div class="case__head">
            <div class="case__meta">
              <Ship class="case__icon" size={18} stroke-width={1.5} aria-hidden="true" />
              <span>importación o&p · hdpe polyfusion</span>
            </div>
            <h3 class="case__title">Importación desde China de principio a fin con IA</h3>
            <p class="case__desc">
              Validación de proveedores, cálculo de transporte internacional + nacionalización y comparativa de cotizaciones. De 6 semanas de investigación manual a 4 días.
            </p>
            <ul class="case__metrics case__metrics--sm">
              <li><strong>−92%</strong><span>tiempo investigación</span></li>
              <li><strong>6→4</strong><span>semanas → días</span></li>
              <li><strong>1</strong><span>operador, sin equipo</span></li>
            </ul>
          </div>

          <!-- Mockup visual: timeline de hitos -->
          <div class="case__visual case__visual--timeline" aria-hidden="true">
            <ol class="tline">
              <li><span class="tline__dot tline__dot--done"></span><div><p class="tline__label">búsqueda</p><p class="tline__sub">6 prov · top 3 con IA</p></div></li>
              <li><span class="tline__dot tline__dot--done"></span><div><p class="tline__label">cotizaciones</p><p class="tline__sub">comparativa de costo total</p></div></li>
              <li><span class="tline__dot tline__dot--done"></span><div><p class="tline__label">transporte</p><p class="tline__sub">china → cartagena</p></div></li>
              <li><span class="tline__dot tline__dot--active"></span><div><p class="tline__label">nacionalización</p><p class="tline__sub">en proceso</p></div></li>
            </ol>
          </div>
        </article>
      </div>

      <!-- Strip de cierre: puente editorial → CTA -->
      <a href={ctaUrl} target="_blank" rel="noopener" class="cases__closer" data-reveal data-magnetic data-magnetic-strength="0.12">
        <span class="cases__closer-text">
          ¿Tu negocio es el <span class="cases__closer-italic">cuarto</span> caso?
        </span>
        <span class="cases__closer-cta">
          <span class="cases__closer-key">CTA-04</span>
          <span class="cases__closer-label">hablar por whatsapp</span>
          <span class="cases__closer-arrow" aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .cases {
    padding-block: clamp(96px, 14vw, 200px);
    border-top: 0.5px solid var(--line);
  }
  .cases__grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
  }
  .cases__content {
    display: flex;
    flex-direction: column;
    gap: clamp(40px, 6vw, 80px);
  }
  .cases__headline {
    margin: 0;
    max-width: 16ch;
  }

  /* Bento */
  .cases__bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .case {
    border: 0.5px solid var(--line);
    border-radius: 4px;
    background-color: var(--bg);
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr;
    transition: border-color 0.3s ease, transform 0.4s var(--ease-out-expo);
    isolation: isolate;
  }
  .case:hover {
    border-color: var(--line-hi);
    transform: translateY(-2px);
  }

  .case__head {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .case__meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .case__icon { color: var(--accent); }

  .case__title {
    margin: 0;
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 500;
    color: var(--ink);
  }

  .case__desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--mute);
  }

  .case__metrics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    border-top: 0.5px solid var(--line);
    padding-top: 16px;
  }
  .case__metrics li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .case__metrics strong {
    font-family: var(--font-mono);
    font-size: 22px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    font-weight: 500;
  }
  .case__metrics span {
    font-size: 11px;
    color: var(--mute);
  }

  /* Variante compacta para cards pequeñas del bento */
  .case__metrics--sm {
    gap: 16px;
    padding-top: 14px;
    margin-top: auto;
  }
  .case__metrics--sm strong {
    font-size: 18px;
  }
  .case__metrics--sm span {
    font-size: 10px;
    letter-spacing: 0.04em;
  }

  /* Strip de cierre del bento */
  .cases__closer {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: clamp(24px, 4vw, 40px);
    padding: clamp(28px, 4vw, 40px) clamp(24px, 3vw, 36px);
    border: 0.5px solid var(--line);
    border-radius: 4px;
    background-color: var(--bg);
    color: var(--ink);
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease,
      transform 0.4s var(--ease-out-expo);
    will-change: transform;
  }
  .cases__closer:hover {
    border-color: var(--ink);
    background-color: var(--bg-soft);
  }
  .cases__closer-text {
    font-family: var(--font-serif);
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink);
    max-width: 22ch;
  }
  .cases__closer-italic {
    font-style: italic;
    text-decoration-line: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }
  .cases__closer-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    align-self: flex-start;
    padding: 10px 0;
    border-top: 0.5px solid var(--line);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--mute);
    width: 100%;
  }
  .cases__closer-key {
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 10px;
  }
  .cases__closer-label {
    color: var(--ink);
    margin-left: auto;
  }
  .cases__closer-arrow {
    color: var(--accent);
    transition: transform 0.3s var(--ease-out-expo);
  }
  .cases__closer:hover .cases__closer-arrow {
    transform: translateX(4px);
  }

  @media (min-width: 768px) {
    .cases__closer {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
    }
    .cases__closer-cta {
      border-top: 0;
      width: auto;
      padding: 0;
    }
    .cases__closer-label { margin-left: 0; }
  }

  /* Visual area */
  .case__visual {
    background-color: var(--bg-soft);
    border-top: 0.5px solid var(--line);
    padding: 24px;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* WhatsApp mockup */
  .wa {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-width: 320px;
  }
  .wa__head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 10px;
    border-bottom: 0.5px solid var(--line);
  }
  .wa__avatar {
    width: 32px; height: 32px;
    border-radius: 9999px;
    background-color: var(--accent);
    flex-shrink: 0;
  }
  .wa__name {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }
  .wa__status {
    margin: 0;
    font-size: 10px;
    color: var(--accent);
    font-family: var(--font-mono);
  }
  .wa__bubble {
    background-color: var(--bg-soft);
    border-radius: 4px;
    padding: 10px 12px;
    align-self: flex-start;
    max-width: 90%;
    font-size: 12px;
    line-height: 1.5;
    color: var(--mute);
  }
  .wa__bubble--user {
    align-self: flex-end;
    background-color: var(--accent-soft);
    color: var(--ink);
  }
  .wa__line { margin: 0; }
  .wa__line strong { color: var(--accent); font-weight: 500; }
  .wa__line--alert { color: var(--negative); margin-top: 4px; font-size: 11px; }

  /* Bar chart */
  .chart__caption {
    margin: 0 0 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .chart {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 4px;
    align-items: end;
    height: 140px;
    margin-bottom: 10px;
  }

  /* Anotación editorial sobre el valle */
  .chart__annotation {
    position: absolute;
    /* Cubre desde la barra 5 hasta la 8 (índices 4-7) sobre el valle */
    left: calc(((100% + 4px) / 12) * 4);
    width: calc(((100% + 4px) / 12) * 4 - 4px);
    bottom: 38%;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
    transition-delay: 900ms;
  }
  .case.is-revealed .chart__annotation {
    opacity: 1;
    transform: translateY(0);
  }
  .chart__annotation-line {
    width: 100%;
    height: 1px;
    background-color: var(--accent);
  }
  .chart__annotation-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--accent);
    white-space: nowrap;
    font-weight: 500;
  }
  .chart__bar {
    background-color: var(--ink);
    height: var(--h, 50%);
    opacity: 0.18;
    border-radius: 2px 2px 0 0;
    transform-origin: bottom;
    transform: scaleY(0);
    transition: transform 0.6s var(--ease-out-expo);
    transition-delay: calc(var(--i, 0) * 50ms + 200ms);
  }
  :global([data-theme='dark']) .chart__bar {
    opacity: 0.30;
  }
  .case.is-revealed .chart__bar { transform: scaleY(1); }
  /* Highlight valley bars */
  .chart__bar:nth-child(5),
  .chart__bar:nth-child(6),
  .chart__bar:nth-child(7),
  .chart__bar:nth-child(8) {
    background-color: var(--accent);
    opacity: 1;
  }

  .chart__legend {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--mute);
  }
  .chart__valley { color: var(--accent); }

  /* Timeline */
  .tline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
  }
  .tline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 8px;
    width: 0.5px;
    background-color: var(--line);
  }
  .tline li {
    position: relative;
    display: grid;
    grid-template-columns: 12px 1fr;
    gap: 12px;
    align-items: flex-start;
  }
  .tline__dot {
    width: 11px;
    height: 11px;
    margin-top: 4px;
    border-radius: 9999px;
    border: 0.5px solid var(--line-hi);
    background-color: var(--bg);
    z-index: 1;
  }
  .tline__dot--done {
    background-color: var(--mute);
    border-color: var(--mute);
  }
  .tline__dot--active {
    background-color: var(--accent);
    border-color: var(--accent);
  }
  .tline__label {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }
  .tline__sub {
    margin: 0;
    font-size: 11px;
    color: var(--mute);
    font-family: var(--font-mono);
  }

  /* Bento layout — desktop */
  @media (min-width: 900px) {
    .cases__bento {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: auto auto;
      gap: 16px;
    }
    .case--lg {
      grid-column: 1 / -1;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      grid-template-rows: 1fr;
    }
    .case--lg .case__visual {
      border-top: 0;
      border-left: 0.5px solid var(--line);
    }
    .case__head { padding: 32px; }
    .case__visual { padding: 32px; }
  }

  @media (min-width: 1024px) {
    .cases__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
