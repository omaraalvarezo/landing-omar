---
// src/components/CalEmbed.astro
// CTA que abre el modal de Cal.com para agendar onboarding de 20 minutos.
//
// Uso básico:
//   <CalEmbed text="agendar onboarding →" variant="bronce" />
//
// Cuando se active cobro en el futuro (mes 5+), basta con:
//   1. Sumar la prop microcopy con el texto del precio.
//   2. Cambiar el calLink al evento pago en Cal.com.
//   No hay que reescribir el componente.

export interface Props {
  text?: string;
  variant?: 'primary' | 'bronce' | 'terracota' | 'indigo' | 'musgo';
  calLink?: string;
  microcopy?: string;   // FUTURO · descripción debajo del botón (ej. precio + descuento)
  className?: string;
}

const {
  text = 'agendar onboarding · 20 min →',
  variant = 'primary',
  calLink = 'omaralvarez/onboarding-20min',
  microcopy,
  className = '',
} = Astro.props;

// Mapa de variantes a HEX (paleta omar-brand)
const variantColors: Record<string, string> = {
  primary: '#1C1917',     // sumi
  bronce: '#8B6F47',      // bronce
  terracota: '#C67B5C',   // terracota
  indigo: '#3D4E6B',      // indigo
  musgo: '#6B7F5C',       // musgo
};
const accent = variantColors[variant] || variantColors.primary;
---

<div class={`cal-cta-wrap ${className}`}>
  <button
    type="button"
    data-cal-namespace="onboarding-20min"
    data-cal-link={calLink}
    data-cal-config='{"layout":"month_view","theme":"light"}'
    class={`cal-cta cal-cta--${variant}`}
    style={`--cal-accent: ${accent};`}
    aria-label={text}
  >
    {text}
  </button>

  {microcopy && (
    <p class="cal-cta-micro" style={`--cal-accent: ${accent};`}>
      {microcopy}
    </p>
  )}
</div>

<script>
  // Inicializa el embed de Cal.com una sola vez por carga.
  // El paquete @calcom/embed-snippet inyecta window.Cal y la API global.
  // Los botones con `data-cal-link` + `data-cal-namespace` quedan activos al cargar el snippet.
  import Cal from '@calcom/embed-snippet';

  declare global {
    interface Window {
      Cal: any;
      __calOnboardingReady?: boolean;
    }
  }

  if (!window.__calOnboardingReady) {
    Cal();
    window.Cal('init', 'onboarding-20min', { origin: 'https://cal.com' });
    window.Cal.ns['onboarding-20min']('ui', {
      cssVarsPerTheme: {
        light: { 'cal-brand': '#C67B5C' },
      },
      hideEventTypeDetails: false,
      layout: 'month_view',
    });
    window.__calOnboardingReady = true;
  }
</script>

<style>
  .cal-cta-wrap {
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }
  .cal-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--cal-accent);
    background: transparent;
    border: 1px solid var(--cal-accent);
    border-radius: 2px;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease;
  }
  .cal-cta:hover {
    background-color: var(--cal-accent);
    color: var(--bg);
  }
  .cal-cta:focus-visible {
    outline: 2px solid var(--cal-accent);
    outline-offset: 4px;
  }
  .cal-cta-micro {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--mute);
  }
</style>
