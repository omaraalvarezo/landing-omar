---
import { whatsappUrl } from '../lib/contact';

const ctaUrl = whatsappUrl(
  'Hola Omar, vi tu landing y quiero agendar una consultoría.'
);

const today = new Date();
const stamp = `${today.getFullYear()}.${String(today.getMonth() + 1).padStart(2, '0')}.${String(today.getDate()).padStart(2, '0')}`;
---

<section id="hero" class="hero">
  <div class="hero__inner container-page">
    <!-- Header recurrente: pilar + path/timestamp -->
    <div class="hero__top">
      <p class="hero__pillar">PERFIL · OPERADOR EDITORIAL</p>
      <p class="hero__path">~/omar.alvarez · {stamp}</p>
    </div>

    <!-- Pill superior: estado disponible -->
    <p class="hero__badge" data-reveal>
      <span class="hero__badge-dot-wrap" aria-hidden="true">
        <span class="hero__badge-dot"></span>
        <span class="hero__badge-pulse"></span>
      </span>
      DISPONIBLE · CÚCUTA, CO
    </p>

    <!-- Headline editorial: Instrument Serif Regular -->
    <h1 class="hero__headline display-1" data-split-reveal style="--reveal-delay: 200ms; --reveal-stagger: 50ms;">
      IA aplicada a la operación real de pymes en LATAM.
    </h1>

    <!-- Subheadline en mono -->
    <p class="hero__sub body-lg" data-reveal style="--reveal-delay: 700ms;">
      Operador de dos negocios. Documento lo que construyo: IA, finanzas, procesos. Sin teoría, sin gurús.
    </p>

    <!-- CTAs -->
    <div class="hero__ctas" data-reveal style="--reveal-delay: 850ms;">
      <a
        href={ctaUrl}
        target="_blank"
        rel="noopener"
        class="hero__cta hero__cta--primary"
        data-magnetic
        data-magnetic-strength="0.25"
      >
        agendar por whatsapp
        <span class="hero__cta-arrow" aria-hidden="true">→</span>
      </a>
      <a
        href="#casos"
        class="hero__cta hero__cta--ghost"
        data-magnetic
        data-magnetic-strength="0.15"
      >
        ver casos
      </a>
    </div>

    <!-- Métricas + scroll indicator -->
    <div class="hero__bottom" data-reveal style="--reveal-delay: 1000ms;">
      <ul class="hero__metrics" aria-label="Métricas operacionales">
        <li class="hero__metric">
          <span class="hero__metric-value number-display" data-counter="81" data-counter-format="money-m" aria-label="$81 millones de pesos colombianos por mes">$0M</span>
          <span class="hero__metric-label">cop/mes operados</span>
        </li>
        <li class="hero__metric">
          <span class="hero__metric-value number-display" data-counter="2" data-counter-duration="900">0</span>
          <span class="hero__metric-label">negocios activos</span>
        </li>
        <li class="hero__metric">
          <span class="hero__metric-value number-display" data-counter="1340" data-counter-format="thousand">0</span>
          <span class="hero__metric-label">reservas analizadas</span>
        </li>
      </ul>

      <div class="hero__scroll" aria-hidden="true">
        <span class="hero__scroll-line"></span>
        <span class="hero__scroll-label">scroll</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    width: 100%;
    overflow: hidden;
  }

  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100svh;
    padding-top: clamp(96px, 14vh, 140px);
    padding-bottom: clamp(32px, 6vh, 64px);
    gap: clamp(20px, 3vh, 32px);
  }

  /* Top: pillar + path */
  .hero__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 12px;
    border-bottom: 0.5px solid var(--line);
    margin-bottom: clamp(16px, 3vh, 24px);
  }
  .hero__pillar {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .hero__path {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--mute);
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    align-self: flex-start;
    padding: 6px 12px;
    border: 0.5px solid var(--line);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--mute);
    margin: 0;
  }
  .hero__badge-dot-wrap {
    position: relative;
    display: inline-block;
    width: 8px;
    height: 8px;
  }
  .hero__badge-dot {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background-color: var(--accent);
  }
  .hero__badge-pulse {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background-color: var(--accent);
    opacity: 0.6;
    transform: scale(1);
    animation: pulse-clean 2.4s var(--ease-out-expo) infinite;
  }
  @keyframes pulse-clean {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    70% { transform: scale(2.4); opacity: 0; }
  }

  /* Headline */
  .hero__headline {
    margin: 0;
    max-width: 16ch;
    color: var(--ink);
  }

  /* Subheadline */
  .hero__sub {
    margin: 0;
    max-width: 56ch;
    color: var(--ink-soft);
    font-family: var(--font-mono);
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .hero__cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    border-radius: 0;
    transition: opacity 0.3s var(--ease-out-expo);
    will-change: transform;
  }
  .hero__cta--primary {
    background-color: var(--accent);
    color: var(--bg);
  }
  .hero__cta--primary:hover {
    opacity: 0.85;
  }

  .hero__cta--ghost {
    background-color: transparent;
    color: var(--ink);
    border: 0.5px solid var(--line-hi);
  }
  .hero__cta--ghost:hover {
    border-color: var(--ink);
  }

  .hero__cta-arrow {
    display: inline-block;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .hero__cta--primary:hover .hero__cta-arrow {
    transform: translateX(3px);
  }

  /* Bottom row */
  .hero__bottom {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: auto;
    padding-top: clamp(32px, 6vh, 56px);
  }

  .hero__metrics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .hero__metric {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 16px;
    border-left: 0.5px solid var(--line);
  }
  .hero__metric-value {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
  }
  .hero__metric-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--mute);
  }

  /* Scroll indicator */
  .hero__scroll {
    display: none;
  }

  /* Tablet+ */
  @media (min-width: 640px) {
    .hero__metrics {
      grid-template-columns: repeat(3, minmax(0, max-content));
      gap: 32px;
    }
    .hero__metric {
      padding-left: 20px;
    }
  }

  @media (min-width: 768px) {
    .hero__bottom {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 32px;
    }
    .hero__scroll {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      align-self: flex-end;
    }
    .hero__scroll-line {
      display: block;
      width: 1px;
      height: 40px;
      background-color: var(--line-hi);
      transform-origin: top center;
      animation: scroll-line 1.6s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    }
    .hero__scroll-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--mute);
      font-weight: 500;
    }
    @keyframes scroll-line {
      0% { transform: scaleY(0); transform-origin: top center; }
      45% { transform: scaleY(1); transform-origin: top center; }
      55% { transform: scaleY(1); transform-origin: bottom center; }
      100% { transform: scaleY(0); transform-origin: bottom center; }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__badge-pulse,
    .hero__scroll-line {
      animation: none !important;
    }
  }
</style>

<script>
  import { splitAndReveal } from '../scripts/splitText';
  import { initCounters } from '../scripts/counter';
  import { initMagnetic } from '../scripts/magnetic';

  splitAndReveal({ selector: '[data-split-reveal]', staggerMs: 50, durationMs: 800 });
  initCounters();
  initMagnetic();

  const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]:not([data-split-reveal])');
  if (reveals.length) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      reveals.forEach((el) => el.classList.add('is-revealed'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-revealed');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      reveals.forEach((el) => io.observe(el));
    }
  }
</script>
