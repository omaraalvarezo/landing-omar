---
import SectionLabel from './SectionLabel.astro';
import { WHATSAPP_NUMBER, TIMEZONE, EMAIL, whatsappUrl } from '../lib/contact';

const directWhatsapp = whatsappUrl('Hola Omar, quiero hablar directamente.');
const directEmail = `mailto:${EMAIL}?subject=${encodeURIComponent('Consultoría IA — landing')}`;
---

<section id="contacto" class="contact scroll-mt-24" aria-labelledby="contact-title">
  <div class="container-page contact__grid">
    <div class="contact__label">
      <SectionLabel number="07" title="CONTACTO" />
    </div>

    <div class="contact__content">
      <h2 id="contact-title" class="display-2 contact__headline" data-split-reveal style="--reveal-stagger: 40ms;">
        ¿Listo para integrar <span class="accent-italic">IA</span> en tu operación?
      </h2>

      <p class="contact__sub body-lg" data-reveal>
        Cuéntame de tu negocio. Te respondo en menos de 24h.
      </p>

      <form class="contact__form" data-reveal data-contact-form data-whatsapp-number={WHATSAPP_NUMBER}>
        <label class="contact__field">
          <span class="sr-only">Tu nombre</span>
          <input
            type="text"
            name="nombre"
            placeholder="tu nombre"
            required
            autocomplete="name"
            class="contact__input"
          />
        </label>

        <label class="contact__field">
          <span class="sr-only">Tu negocio o sector</span>
          <input
            type="text"
            name="negocio"
            placeholder="tu negocio o sector"
            required
            autocomplete="organization"
            class="contact__input"
          />
        </label>

        <label class="contact__field">
          <span class="sr-only">Qué quieres resolver</span>
          <textarea
            name="problema"
            rows="3"
            placeholder="qué quieres resolver"
            required
            class="contact__input contact__textarea"
          ></textarea>
        </label>

        <!-- Calificación opcional (ayuda a Omar a preparar la conversación) -->
        <fieldset class="contact__qualify">
          <legend class="contact__qualify-legend">calificación · opcional</legend>

          <label class="contact__qualify-field">
            <span class="contact__qualify-label">facturación / mes</span>
            <select name="facturacion" class="contact__select">
              <option value="" selected>— sin especificar</option>
              <option value="< $30M COP">menos de $30M cop</option>
              <option value="$30M–$100M COP">$30m — $100m cop</option>
              <option value="$100M–$300M COP">$100m — $300m cop</option>
              <option value="> $300M COP">más de $300m cop</option>
            </select>
          </label>

          <label class="contact__qualify-field">
            <span class="contact__qualify-label">plazo</span>
            <select name="plazo" class="contact__select">
              <option value="" selected>— sin especificar</option>
              <option value="esta semana">esta semana</option>
              <option value="este mes">este mes</option>
              <option value="este trimestre">este trimestre</option>
              <option value="explorando">explorando</option>
            </select>
          </label>
        </fieldset>

        <button type="submit" class="contact__submit" data-magnetic data-magnetic-strength="0.18">
          abrir whatsapp con tu mensaje
          <span class="contact__arrow" aria-hidden="true">→</span>
        </button>

        <!-- Live region: status/errores anunciados a screen readers + visibles.
             Vacío por defecto; el script lo rellena tras el submit. -->
        <p
          class="contact__status"
          data-contact-status
          data-state="idle"
          role="status"
          aria-live="polite"
        ></p>
      </form>

      <p class="contact__meta" data-reveal>
        respuesta promedio: 4 horas · zona horaria {TIMEZONE}
      </p>

      <!-- Alternativa directa: si el form se siente friction, salida fácil -->
      <p class="contact__direct" data-reveal>
        <span class="contact__direct-label">o directo:</span>
        <a href={directWhatsapp} target="_blank" rel="noopener" class="contact__direct-link">whatsapp</a>
        <span aria-hidden="true" class="contact__direct-sep">/</span>
        <a href={directEmail} class="contact__direct-link">email</a>
      </p>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: clamp(120px, 18vw, 240px);
    border-top: 0.5px solid var(--line);
  }
  .contact__grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
  }
  .contact__content {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 720px;
  }
  .contact__headline {
    margin: 0;
    max-width: 18ch;
  }
  .contact__sub {
    margin: 0;
    color: var(--mute);
    max-width: 480px;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 16px;
  }

  .contact__field {
    position: relative;
    display: block;
  }

  .contact__input {
    width: 100%;
    padding: 18px 0 16px;
    background: transparent;
    border: 0;
    border-bottom: 0.5px solid var(--line);
    border-radius: 0;
    color: var(--ink);
    font-family: inherit;
    font-size: clamp(18px, 2.4vw, 24px);
    line-height: 1.4;
    letter-spacing: -0.01em;
    outline: 0;
    transition: border-color 0.4s var(--ease-out-expo);
    position: relative;
  }
  .contact__field::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background-color: var(--accent);
    transition: width 0.5s var(--ease-out-expo);
    pointer-events: none;
  }
  .contact__field:focus-within::after {
    width: 100%;
  }
  .contact__input::placeholder {
    color: var(--mute);
    transition: color 0.3s ease;
  }
  .contact__input:focus,
  .contact__input:focus-visible {
    outline: 0;
    border-bottom-color: transparent;
  }
  .contact__input:focus::placeholder {
    color: var(--mute);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 96px;
  }

  /* Calificación opcional */
  .contact__qualify {
    margin-top: 16px;
    padding: 20px 0 0;
    border: 0;
    border-top: 0.5px solid var(--line);
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .contact__qualify-legend {
    padding: 0 0 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    font-weight: 500;
  }
  .contact__qualify-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .contact__qualify-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--mute);
  }
  .contact__select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    padding: 10px 28px 10px 0;
    background: transparent;
    border: 0;
    border-bottom: 0.5px solid var(--line);
    border-radius: 0;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
    outline: 0;
    cursor: pointer;
    /* Caret editorial: SVG inline stroke 1.5 (sin gradiente) */
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 8' fill='none' stroke='%23525252' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'><path d='M1 1.5 L6 6.5 L11 1.5'/></svg>");
    background-repeat: no-repeat;
    background-position: right 6px center;
    background-size: 10px 7px;
    transition: border-color 0.3s ease, color 0.3s ease;
  }
  .contact__select:hover,
  .contact__select:focus-visible {
    border-bottom-color: var(--accent);
  }
  /* Caret más claro en dark (el SVG inline tiene stroke hardcoded) */
  :global([data-theme='dark']) .contact__select {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 8' fill='none' stroke='%238A8A87' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'><path d='M1 1.5 L6 6.5 L11 1.5'/></svg>");
  }

  @media (min-width: 640px) {
    .contact__qualify {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }

  .contact__submit {
    align-self: flex-start;
    margin-top: 24px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 22px;
    background-color: var(--accent);
    color: var(--bg);
    border: 0;
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  .contact__submit:hover {
    opacity: 0.85;
  }

  .contact__arrow {
    display: inline-block;
    animation: arrow-loop 1.6s var(--ease-out-expo) infinite;
  }
  @keyframes arrow-loop {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(4px); }
  }

  /* Live region: feedback del submit. Texto + icono semántico (no solo color). */
  .contact__status {
    margin: 12px 0 0;
    min-height: 1.4em;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--mute);
    transition: color 0.2s ease;
  }
  .contact__status:empty {
    display: none;
  }
  .contact__status[data-state='success'] {
    color: var(--positive);
  }
  .contact__status[data-state='error'] {
    color: var(--negative);
  }

  .contact__meta {
    margin: 8px 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--mute);
  }

  /* Salida directa: WhatsApp/email sin pasar por el form */
  .contact__direct {
    margin: 4px 0 0;
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--mute);
  }
  .contact__direct-label { color: var(--mute); }
  .contact__direct-link {
    color: var(--ink);
    border-bottom: 0.5px solid var(--line-hi);
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .contact__direct-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .contact__direct-sep { color: var(--line-hi); }

  @media (min-width: 1024px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__arrow { animation: none !important; }
    .contact__input { transition: none !important; }
  }
</style>

<script>
  import { initMagnetic } from '../scripts/magnetic';
  import { whatsappUrl, buildLeadMessage } from '../lib/contact';

  initMagnetic('[data-magnetic]');

  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  const status = document.querySelector<HTMLElement>('[data-contact-status]');

  function setStatus(state: 'idle' | 'loading' | 'success' | 'error', text: string) {
    if (!status) return;
    status.dataset.state = state;
    status.textContent = text;
    // role='alert' para errores (anuncio inmediato); 'status' para info (polite).
    status.setAttribute('role', state === 'error' ? 'alert' : 'status');
  }

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const nombre = String(fd.get('nombre') ?? '').trim();
      const negocio = String(fd.get('negocio') ?? '').trim();
      const problema = String(fd.get('problema') ?? '').trim();
      const facturacion = String(fd.get('facturacion') ?? '').trim() || undefined;
      const plazo = String(fd.get('plazo') ?? '').trim() || undefined;

      // Validación accesible: anuncia el campo faltante y marca aria-invalid.
      const inputs = {
        nombre: form.querySelector<HTMLInputElement>('[name="nombre"]'),
        negocio: form.querySelector<HTMLInputElement>('[name="negocio"]'),
        problema: form.querySelector<HTMLTextAreaElement>('[name="problema"]'),
      };
      Object.values(inputs).forEach((el) => el?.removeAttribute('aria-invalid'));

      if (!nombre || !negocio || !problema) {
        const missing: string[] = [];
        if (!nombre) { missing.push('nombre'); inputs.nombre?.setAttribute('aria-invalid', 'true'); }
        if (!negocio) { missing.push('negocio'); inputs.negocio?.setAttribute('aria-invalid', 'true'); }
        if (!problema) { missing.push('lo que quieres resolver'); inputs.problema?.setAttribute('aria-invalid', 'true'); }
        setStatus('error', `falta · ${missing.join(' · ')}`);
        // Foco en el primer campo faltante para que el usuario lo arregle.
        const first = (!nombre && inputs.nombre) || (!negocio && inputs.negocio) || inputs.problema;
        first?.focus();
        return;
      }

      setStatus('loading', 'abriendo whatsapp…');
      const message = buildLeadMessage({ nombre, negocio, problema, facturacion, plazo });
      const url = whatsappUrl(message);
      const win = window.open(url, '_blank', 'noopener');

      // Si el navegador bloquea el popup, win === null. Damos feedback claro.
      if (!win) {
        setStatus('error', 'tu navegador bloqueó la ventana — usa el enlace directo abajo ↓');
        return;
      }
      setStatus('success', 'listo. abriendo conversación en whatsapp ✓');
    });
  }
</script>
