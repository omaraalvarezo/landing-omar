---
// Loader inicial — pantalla negra full + nombre + barra lima.
// Se monta antes que el resto del DOM y se desmonta a los <1.2s.
// Respeta prefers-reduced-motion (instant skip).
---

<div id="loader" data-state="initial" aria-hidden="true">
  <div class="loader__inner">
    <p class="loader__name">OMAR ÁLVAREZ</p>
    <div class="loader__bar">
      <span class="loader__fill"></span>
    </div>
  </div>
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    background-color: var(--bg);
    pointer-events: none;
    will-change: opacity;
    transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #loader[data-state='done'] {
    opacity: 0;
    pointer-events: none;
  }

  /* Lock scroll while loader is up */
  :global(html:not(.loader-done):not(.loader-skipped)) {
    overflow: hidden;
  }

  .loader__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .loader__name {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--text-mute);
    margin: 0;
  }

  .loader__bar {
    position: relative;
    width: 160px;
    height: 1px;
    background-color: var(--border);
    overflow: hidden;
  }

  .loader__fill {
    position: absolute;
    inset: 0;
    background-color: var(--accent);
    transform-origin: left center;
    transform: scaleX(0);
  }

  #loader[data-state='loading'] .loader__fill {
    animation: loader-fill 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes loader-fill {
    0% { transform: scaleX(0); }
    100% { transform: scaleX(1); }
  }

  /* Reduced motion: skip everything */
  @media (prefers-reduced-motion: reduce) {
    #loader { display: none !important; }
  }
</style>

<script>
  import { initLoader } from '../scripts/loader';
  initLoader();
</script>
