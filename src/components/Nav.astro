---
import { whatsappUrl } from '../lib/contact';
import Logo from './Logo.astro';

interface Props {
  currentPath?: string;
}
const { currentPath = Astro.url.pathname } = Astro.props;
const isHome = currentPath === '/' || currentPath === '';

// Anchors a secciones del home: si estamos en /, usar hash. Si no, prefijar con /.
const anchor = (hash: string) => (isHome ? hash : `/${hash}`);

const NAV_LINKS = [
  { href: anchor('#servicios'), label: 'servicios', match: null },
  { href: anchor('#casos'), label: 'casos', match: null },
  { href: anchor('#metodo'), label: 'método', match: null },
  { href: '/recursos', label: 'recursos', match: '/recursos' },
];

const logoHref = isHome ? '#top' : '/';

const ctaUrl = whatsappUrl(
  'Hola Omar, vi tu landing y quiero agendar una consultoría.'
);

function isActive(match: string | null): boolean {
  return match !== null && currentPath.startsWith(match);
}
---

<header id="site-nav" data-scrolled="false" aria-label="Navegación principal">
  <div class="container-page nav__inner">
    <a href={logoHref} class="nav__logo" aria-label="omar.alvarez · inicio">
      <Logo variant="horizontal" size={18} />
    </a>

    <nav class="nav__links" aria-label="Secciones">
      {NAV_LINKS.map((l) => (
        <a
          href={l.href}
          class={`nav__link${isActive(l.match) ? ' nav__link--active' : ''}`}
          aria-current={isActive(l.match) ? 'page' : undefined}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="nav__cta-wrap">
      <button
        id="theme-toggle"
        class="nav__theme"
        type="button"
        aria-label="Cambiar a tema oscuro"
        aria-pressed="false"
        title="Cambiar tema"
      >
        <svg class="nav__theme-icon nav__theme-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg class="nav__theme-icon nav__theme-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a href={ctaUrl} target="_blank" rel="noopener" class="nav__cta">
        agendar →
      </a>

      <button id="nav-toggle" class="nav__toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-overlay">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div id="nav-overlay" data-state="closed" aria-hidden="true">
  <nav class="nav-overlay__inner container-page" aria-label="Menú móvil">
    <ul>
      {NAV_LINKS.map((l) => (
        <li>
          <a
            href={l.href}
            class={`nav-overlay__link${isActive(l.match) ? ' nav-overlay__link--active' : ''}`}
            aria-current={isActive(l.match) ? 'page' : undefined}
            data-overlay-link
          >
            {l.label}
          </a>
        </li>
      ))}
      <li>
        <a href={ctaUrl} target="_blank" rel="noopener" class="nav-overlay__link nav-overlay__link--cta" data-overlay-link>
          agendar por whatsapp →
        </a>
      </li>
    </ul>
  </nav>
</div>

<style>
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 70;
    height: 80px;
    background-color: var(--bg);
    border-bottom: 0.5px solid transparent;
    transition:
      height 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s ease;
  }

  #site-nav[data-scrolled='true'] {
    height: 60px;
    border-bottom-color: var(--line);
  }

  .nav__inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav__logo {
    display: inline-flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }
  .nav__logo:hover {
    opacity: 0.7;
  }

  .nav__links {
    display: none;
    align-items: center;
    gap: 28px;
  }
  .nav__link {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--mute);
    transition: color 0.2s ease;
  }
  .nav__link:hover { color: var(--ink); }
  .nav__link--active { color: var(--ink); }

  .nav__cta-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav__cta {
    display: none;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background-color: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    border-radius: 0;
    transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav__cta:hover {
    opacity: 0.85;
  }
  @media (min-width: 768px) {
    .nav__cta { display: inline-flex; }
  }

  /* Theme toggle (sol/luna). Vive antes del CTA azul. */
  .nav__theme {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 0.5px solid var(--line);
    border-radius: 0;
    color: var(--ink);
    padding: 0;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .nav__theme:hover { border-color: var(--ink); }
  .nav__theme-icon {
    position: absolute;
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Estado light: el botón ofrece "ir a dark" → mostrar luna */
  .nav__theme-icon--sun { opacity: 0; transform: rotate(-45deg) scale(0.85); }
  .nav__theme-icon--moon { opacity: 1; transform: rotate(0) scale(1); }
  /* Estado dark: el botón ofrece "ir a light" → mostrar sol */
  :global([data-theme='dark']) .nav__theme-icon--sun { opacity: 1; transform: rotate(0) scale(1); }
  :global([data-theme='dark']) .nav__theme-icon--moon { opacity: 0; transform: rotate(45deg) scale(0.85); }

  @media (prefers-reduced-motion: reduce) {
    .nav__theme-icon { transition: opacity 0.01ms ease, transform 0.01ms ease; }
  }

  .nav__toggle {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 0.5px solid var(--line);
    border-radius: 0;
    padding: 0;
  }
  .nav__toggle span {
    display: block;
    width: 14px;
    height: 1px;
    background-color: var(--ink);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease;
  }
  .nav__toggle[aria-expanded='true'] span:first-child {
    transform: translateY(3px) rotate(45deg);
  }
  .nav__toggle[aria-expanded='true'] span:last-child {
    transform: translateY(-3px) rotate(-45deg);
  }

  @media (min-width: 768px) {
    .nav__links { display: flex; }
    .nav__toggle { display: none; }
  }

  /* Mobile overlay */
  #nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 65;
    background-color: var(--bg);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.4s ease;
    overflow-y: auto;
    padding-top: 96px;
    padding-bottom: 48px;
  }
  #nav-overlay[data-state='open'] {
    opacity: 1;
    visibility: visible;
  }

  .nav-overlay__inner ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .nav-overlay__link {
    display: block;
    padding: 16px 0;
    font-family: var(--font-mono);
    font-size: clamp(32px, 8vw, 48px);
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 500;
    color: var(--ink);
    border-bottom: 0.5px solid var(--line);
    transition: opacity 0.2s ease;
  }
  .nav-overlay__link:hover { opacity: 0.7; }
  .nav-overlay__link--active { color: var(--ink); }
  .nav-overlay__link--cta {
    color: var(--accent);
    margin-top: 16px;
    border-bottom: 0;
  }

  @media (min-width: 768px) {
    #nav-overlay { display: none; }
  }
</style>

<script>
  // --- Scroll shrink ---
  const nav = document.getElementById('site-nav');
  if (nav) {
    let last = -1;
    function onScroll() {
      const scrolled = window.scrollY > 16;
      const v = scrolled ? 1 : 0;
      if (v === last) return;
      last = v;
      nav!.dataset.scrolled = String(scrolled);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // --- Mobile overlay toggle ---
  const toggle = document.getElementById('nav-toggle');
  const overlay = document.getElementById('nav-overlay');
  function setOpen(open: boolean) {
    if (!toggle || !overlay) return;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    overlay.dataset.state = open ? 'open' : 'closed';
    overlay.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  }
  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });
  overlay?.querySelectorAll('[data-overlay-link]').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
    }
  });

  // Close overlay if viewport grows past mobile breakpoint
  const mq = window.matchMedia('(min-width: 768px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });
</script>
