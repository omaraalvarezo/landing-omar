#!/bin/sh
# Pre-commit local: bloquea commits con secrets en archivos staged.
# - Si `gitleaks` está instalado globalmente (brew install gitleaks), corre el scan completo.
# - Si no, hace un fallback con grep contra patterns críticos del stack.
# El CI (.github/workflows/security.yml) corre gitleaks oficial siempre — esto es defense-in-depth local.

set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '^(node_modules/|dist/|\.astro/|\.vercel/|\.husky/|\.gitleaks\.toml$)' || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

# Camino A: gitleaks instalado
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner --config .gitleaks.toml
  exit $?
fi

# Camino B: fallback con grep simple
echo "→ gitleaks no instalado, usando fallback de patrones críticos…"
echo "  (instálalo con: brew install gitleaks)"
echo

PATTERNS='(cal_live_[a-f0-9]{32}|cal_test_[a-f0-9]{32}|sk_live_[A-Za-z0-9]{20,}|sk_test_[A-Za-z0-9]{20,}|ghp_[A-Za-z0-9]{36}|gho_[A-Za-z0-9]{36}|xoxb-[A-Za-z0-9-]{50,}|AKIA[0-9A-Z]{16}|\$2[abxy]\$[0-9]{2}\$[./A-Za-z0-9]{53}|-----BEGIN.*PRIVATE KEY-----)'

HITS=""
for f in $STAGED; do
  if [ -f "$f" ] && [ "$(wc -c < "$f")" -lt 5000000 ]; then
    if grep -lE "$PATTERNS" "$f" 2>/dev/null; then
      HITS="$HITS $f"
    fi
  fi
done

if [ -n "$HITS" ]; then
  echo
  echo "✗ Posibles secretos detectados en:"
  echo "$HITS" | tr ' ' '\n' | sed 's/^/    /'
  echo
  echo "  Revisa los archivos y limpia si aplica."
  echo "  Si es un falso positivo, edita .gitleaks.toml o usa: git commit --no-verify"
  exit 1
fi

exit 0
